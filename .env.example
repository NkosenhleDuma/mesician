# Copy to `.env` and adjust. Used by Docker Compose (Postgres + MinIO) and by the Next.js app (`npm run dev`).
#
# Postgres + MinIO + one-shot Kysely migrator:
#   docker compose --env-file .env -f docker-compose.local.yml up -d postgres minio migrate
#
# Infra only (then run migrations yourself: `npm run db:migrate`):
#   docker compose --env-file .env -f docker-compose.local.yml up -d postgres minio

# --- Postgres (matches docker-compose.local.yml `postgres` service) ---
POSTGRES_USER=mesician
POSTGRES_PASSWORD=mesician
POSTGRES_DB=mesician
# Optional host port mapping (compose): defaults 5432
# POSTGRES_PORT=5432

# App connection from host (Next.js on your machine → Postgres in Docker).
# If you change user/password/db above, update this URL to match.
DATABASE_URL=postgres://mesician:mesician@localhost:5432/mesician

# --- MinIO (S3-compatible API; console http://localhost:9001 ) ---
# Uploads need free space on the MinIO data filesystem (see docs/troubleshooting.md).
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
# Optional host port mapping (compose): API 9000, console 9001
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=mesician

# --- Next.js / auth ---
# Min 16 characters (see src/lib/env.ts)
JWT_SECRET=dev-secret-change-me-in-prod-32chars

NEXT_PUBLIC_APP_URL=http://localhost:3000
